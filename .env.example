
# ⚠️ ВАЖЛИВО: НЕ додавайте префікс VITE_ до секретних змінних!
# Змінні з VITE_ потрапляють у клієнтський bundle і стають публічними.

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/technorent"
JWT_SECRET="generate-with-openssl-rand-base64-32"
ADMIN_EMAIL="admin"
ADMIN_PASSWORD="your-secure-password"
PORT=3001
CLIENT_URL="http://localhost:5173"
SITE_URL="https://technorent.ua"
# Canonical/OG URL for public pages. Keep aligned with SITE_URL after the final domain is approved.
SEO_SITE_URL="https://technorent.ua"
NODE_ENV="development"

# Telegram notifications for orders and service requests
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_INTERNAL_TOKEN=""
TELEGRAM_BOT_PORT=3011
TELEGRAM_BOT_WEBHOOK_SECRET="change-me"
BACKEND_INTERNAL_URL="http://127.0.0.1:3001/api/internal/telegram"
LOCAL_BACKEND_INTERNAL_URL="http://127.0.0.1:3001/api/internal/telegram"
PRODUCTION_BACKEND_INTERNAL_URL="http://technorent.lanbox.com.ua/api/internal/telegram"
TELEGRAM_BOT_INTERNAL_URL="http://127.0.0.1:3011/internal"

# Customer account verification. Do not expose these through VITE_*.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
CUSTOMER_EMAIL_OTP_FROM="TechnoRent <no-reply@technorent.ua>"
VIBER_BOT_TOKEN=""

# Monobank acquiring. Секретний токен тільки на backend, без VITE_.
MONOBANK_MERCHANT_TOKEN=""
MONOBANK_API_BASE_URL="https://api.monobank.ua"
MONOBANK_WEBHOOK_URL="https://your-domain.example/api/payments/monobank/webhook"
MONOBANK_REDIRECT_URL="https://your-domain.example/"
# Опційно: додатковий секрет у path, якщо MONOBANK_WEBHOOK_URL містить /webhook/<secret>
MONOBANK_WEBHOOK_SECRET=""
# Для локального тесту без реального підпису можна тимчасово поставити false.
MONOBANK_VERIFY_WEBHOOK="true"
# Опційно: публічний ключ monobank, якщо не хочеш отримувати його через API.
MONOBANK_PUBLIC_KEY=""

# EquGPS / Traccar-compatible tracker source
EQUGPS_BASE_URL="https://trace.equgps.com"
EQUGPS_EMAIL=""
EQUGPS_PASSWORD=""

# Єдина безпечна клієнтська змінна:
# VITE_API_URL="http://localhost:3001/api"
# VITE_SITE_URL="https://technorent.ua"
# VITE_GTM_ID="GTM-XXXXXXX"
# GA4 Measurement ID можна тримати лише для довідки/налаштування GTM, у коді зараз використовується GTM:
# GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
