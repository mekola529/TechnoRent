// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  engineType    = "binary"
  binaryTargets = ["native", "debian-openssl-1.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Техніка ──────────────────────────────────────

model Equipment {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  brand       String
  type        EquipmentType
  description String
  pricePerHour Int
  isPopular   Boolean  @default(false)
  baseAddress   String?
  baseLatitude  Float?
  baseLongitude Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  specs         EquipmentSpec[]
  images        EquipmentImage[]
  bookedPeriods BookedPeriod[]
  orders        Order[]
  rentOrderItems RentOrderItem[]

  @@index([type])
  @@index([brand])
  @@index([isPopular])
}

model EquipmentSpec {
  id          String    @id @default(cuid())
  label       String
  value       String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
}

model EquipmentImage {
  id          String    @id @default(cuid())
  url         String
  alt         String
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
}

model BookedPeriod {
  id          String    @id @default(cuid())
  from        DateTime
  to          DateTime
  note        String?
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  orderId       String?
  order         Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  rentOrderId   String?
  rentOrder     RentOrder?  @relation(fields: [rentOrderId], references: [id], onDelete: SetNull)

  @@index([equipmentId])
  @@index([from, to])
  @@index([rentOrderId])
}

// ─── Замовлення ───────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  customerName  String
  phone         String
  email         String?
  dateFrom      DateTime?
  dateTo        DateTime?
  address       String?
  comment       String?
  status        OrderStatus @default(NEW)
  equipmentId   String?
  equipment     Equipment?  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  bookedPeriods BookedPeriod[]
  rentOrders    RentOrder[]

  @@index([status])
  @@index([equipmentId])
}

// ─── Заявки на послуги ────────────────────────────

model ServiceRequest {
  id           String              @id @default(cuid())
  serviceType  String              // e.g. "debris_removal"
  customerName String
  phone        String
  address      String
  date         DateTime
  time         String              // e.g. "09:00" or "09:00-12:00"
  comment      String?
  status       OrderStatus         @default(NEW)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([status])
  @@index([serviceType])
}

// ─── Замовлення (оформлені оренди) ────────────────

model RentOrder {
  id              String          @id @default(cuid())
  customerName    String
  customerPhone   String
  status          RentOrderStatus @default(NEW)
  comment         String?
  sourceType      String          @default("manual")
  sourceRequestId String?
  sourceRequest   Order?          @relation(fields: [sourceRequestId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items           RentOrderItem[]
  bookedPeriods   BookedPeriod[]

  @@index([status])
  @@index([sourceRequestId])
}

model RentOrderItem {
  id          String    @id @default(cuid())
  rentOrderId String
  rentOrder   RentOrder @relation(fields: [rentOrderId], references: [id], onDelete: Cascade)
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime

  @@index([rentOrderId])
  @@index([equipmentId])
}

// ─── Адміністратори ───────────────────────────────

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         AdminRole @default(MANAGER)
  createdAt    DateTime  @default(now())
}

// ─── Послуги (Services) ───────────────────────────

model Service {
  id                    String          @id @default(cuid())
  slug                  String          @unique
  title                 String
  shortDescription      String
  fullDescription       String
  image                 String
  priceInfo             String
  pricingType           PricingType     @default(custom)
  deliveryRatePerKm     Float?
  relatedEquipmentTypes EquipmentType[]
  features              String[]
  seoTitle              String
  seoDescription        String
  isActive              Boolean         @default(true)
  sortOrder             Int             @default(0)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([isActive, sortOrder])
}

// ─── Матеріали і точки постачання ─────────────────

model Material {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  unit             String
  isActive         Boolean  @default(true)
  minOrderQuantity Float?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  offers SupplierMaterialOffer[]

  @@index([isActive, sortOrder])
}

model SupplierPoint {
  id           String   @id @default(cuid())
  name         String
  address      String
  latitude     Float
  longitude    Float
  isActive     Boolean  @default(true)
  contactName  String?
  contactPhone String?
  workHours    String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  offers SupplierMaterialOffer[]

  @@index([isActive])
  @@index([latitude, longitude])
}

model SupplierMaterialOffer {
  id                 String   @id @default(cuid())
  supplierPointId    String
  supplierPoint      SupplierPoint @relation(fields: [supplierPointId], references: [id], onDelete: Cascade)
  materialId         String
  material           Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  unitPrice          Float
  isAvailable        Boolean  @default(true)
  minOrderQuantity   Float?
  lastPriceUpdatedAt DateTime?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([supplierPointId, materialId])
  @@index([supplierPointId])
  @@index([materialId])
  @@index([isAvailable])
}

// ─── Enums ────────────────────────────────────────

enum PricingType {
  fixed_from
  hourly_from
  calculator
  tow_calculator
  material_delivery_calculator
  custom
}

enum EquipmentType {
  excavator
  loader
  bulldozer
  crane
  roller
  dump_truck
  concrete_mixer
  generator
  other
}

enum OrderStatus {
  NEW
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RentOrderStatus {
  NEW
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum AdminRole {
  ADMIN
  MANAGER
}
